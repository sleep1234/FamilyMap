<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>FamilyMap</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>familymap</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- App Transport Security -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<!-- Location Permissions -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>FamilyMap needs your location to share real-time position with family members.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>FamilyMap needs continuous location access to share your position with family in the background.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>FamilyMap needs your location to share real-time position with family, including when running in background.</string>

	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>processing</string>
		<string>audio</string>
	</array>

	<!-- Microphone (record plugin) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>FamilyMap needs microphone access to record voice messages.</string>

	<!-- Camera & Photo Library (image_picker plugin) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>FamilyMap needs photo library access to select profile avatars.</string>
	<key>NSCameraUsageDescription</key>
	<string>FamilyMap needs camera access to take profile photos.</string>

	<!-- Motion & Fitness (activity_recognition_flutter plugin - REQUIRED) -->
	<key>NSMotionUsageDescription</key>
	<string>FamilyMap needs motion data to detect your activity (walking, driving, etc.) and share status with family.</string>

	<!-- FaceID (if needed) -->
	<key>NSFaceIDUsageDescription</key>
	<string>FamilyMap uses FaceID for secure authentication.</string>

	<!-- App lifecycle -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
