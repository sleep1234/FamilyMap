# FamilyMap 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器端口
PORT=8090

# 服务器监听地址
HOST=0.0.0.0

# 高德地图 Web 服务 API Key
AMAP_KEY=你的高德Key

# 密码加密盐值（生产环境必须修改为随机强密码）
PWD_SALT=请替换为随机字符串

# SSL 证书路径（可选，配置后启用 HTTPS）
# SSL_CERT_PATH=/path/to/fullchain.crt
# SSL_KEY_PATH=/path/to/private.key

# 管理员用户 ID（逗号分隔，留空则禁止所有管理操作）
# ADMIN_USER_IDS=u_xxxx

# 数据库文件路径（可选，默认 familymap.db）
# DB_PATH=./familymap.db
